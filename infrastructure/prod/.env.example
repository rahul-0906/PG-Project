# ──────────────────────────────────────────────────────────────────────────────
# PG CRM PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the actual production values.
# ──────────────────────────────────────────────────────────────────────────────

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# ─── DATABASE CONFIGURATION ──────────────────────────────────────────────────
# The database URL points to the postgres container inside the docker network
DB_URL=jdbc:postgresql://postgres:5432/pgcrmdb
DB_USERNAME=postgres
DB_PASSWORD=your_secure_production_db_password

# ─── SECURITY & AUTHENTICATION ───────────────────────────────────────────────
# Secret key for signing JWTs. Must be a cryptographically secure 256-bit hex/string.
JWT_SECRET=your_cryptographically_secure_256_bit_jwt_secret_key_here

# ─── INITIAL SYSTEM OWNER ONBOARDING ──────────────────────────────────────────
# Automated production onboarding credentials for the primary account
PG_DEFAULT_OWNER_EMAIL=owner@pgcrm.com
PG_DEFAULT_OWNER_NAME=System Owner
PG_DEFAULT_OWNER_PASSWORD=Owner@123_change_me_on_first_login

# ─── TENANT BRANDING CONFIGURATION ───────────────────────────────────────────
PG_NAME=Sai Balaji PG
PG_SHORT_NAME=Sai Balaji
PG_PRIMARY_COLOR=#2563eb

# ─── SMTP EMAIL INTEGRATION ──────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=notifications@yourdomain.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=noreply@yourdomain.com
MAIL_ENABLED=true

# ─── RAZORPAY INTEGRATION ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_your_live_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret
RAZORPAY_ENABLED=true

# ─── META WHATSAPP CLOUD API INTEGRATION ─────────────────────────────────────
META_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_configured_in_meta_developer_portal
