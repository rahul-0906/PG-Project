# ─────────────────────────────────────────────────────────────────────────────
# PG CRM — Environment Variables Template
# Copy this file to .env and fill in real values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=pgcrm123          # PostgreSQL password

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=ChangeThisToASecureRandomStringOfAtLeast256BitsForHS256Algorithm

# ── Gmail / Email ─────────────────────────────────────────────────────────────
MAIL_ENABLED=false            # Set to true to enable email notifications
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password   # Generate from Google Account → App Passwords

# ── Razorpay (Payment Gateway) ───────────────────────────────────────────────
RAZORPAY_ENABLED=false        # Set to true to enable live payments
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Twilio (WhatsApp Notifications) ──────────────────────────────────────────
TWILIO_ENABLED=false          # Set to true to enable WhatsApp messages
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
